<apex:page showHeader="false" sidebar="false" standardStylesheets="false">
    <html>
    <head>
        <title>DocGen PDF Engine</title>
        <!-- Load Libraries from Static Resources -->
        <script src="{!URLFOR($Resource.DocGenEngine, 'html2pdf.js')}"></script>
        <style>
            /* Critical CSS for formatting */
            body {
                font-family: 'Arial', sans-serif;
                margin: 0;
                padding: 20px;
                background: white;
            }

            /* Page Break Rules */
            p, li, span, div {
                orphans: 3 !important;
                widows: 3 !important;
            }

            table, tr, td, th {
                page-break-inside: avoid !important;
            }

            h1, h2, h3, h4 {
                page-break-after: avoid !important;
            }

            /* Keep paragraphs together when possible */
            p {
                page-break-inside: avoid !important;
            }

            /* Print Media Query */
            @media print {
                body {
                    margin: 0;
                    padding: 0;
                }
                .page-break {
                    page-break-before: always;
                }
            }

        /* OVERRIDES for docx-preview internal structure */
        .docx-wrapper {
            padding: 0 !important;
            margin: 0 !important;
            background: transparent !important;
        }
        section.docx-render {
            margin: 0 !important;
            padding: 0 !important;
        }
    </style>
</head>
    <body>
        <!-- Standard Letter Width: 816px. Hidden until needed. -->
        <div id="content-zone" style="display:none; width: 816px; margin: 0; background: white; padding: 0; box-sizing: border-box;"></div>

        <!-- DOCX Preview for High Fidelity Rendering -->
        <script src="{!URLFOR($Resource.DocGenEngine, 'jszip.min.js')}"></script>
        <script src="{!URLFOR($Resource.DocGenEngine, 'docx-preview.js')}"></script>

        <script>
            // Store the LWC parent origin from the first message received.
            // VF pages run on a different domain (visualforce.com) than LWC
            // (lightning.force.com), so we capture the sender origin dynamically.
            var parentOrigin = null;

            // Validate that a message origin belongs to a Salesforce domain
            function isSalesforceOrigin(origin) {
                if (!origin) return false;
                return /\.(lightning\.force|salesforce|visualforce|force)\.com$/.test(origin);
            }

            // Wait for all images in container to finish loading
            function waitForImages(container) {
                var images = container.querySelectorAll('img');
                var promises = Array.from(images).map(function(img) {
                    if (img.complete && img.naturalHeight !== 0) return Promise.resolve();
                    return new Promise(function(resolve) {
                        img.onload = resolve;
                        img.onerror = resolve;
                        setTimeout(resolve, 5000);
                    });
                });
                return Promise.all(promises);
            }

            // Wait for browser to finish painting
            function waitForPaint() {
                return new Promise(function(resolve) {
                    requestAnimationFrame(function() {
                        requestAnimationFrame(resolve);
                    });
                });
            }

            // Listen for messages from LWC
            window.addEventListener('message', async function(event) {
                var data = event.data;
                if (!data || data.type !== 'generate') return;

                // Validate sender is a Salesforce domain
                if (!isSalesforceOrigin(event.origin)) return;

                // Capture the LWC origin for reply messages
                parentOrigin = event.origin;
                if (data.type === 'generate') {
                    try {
                        var blob = new Blob([data.blob], { type: 'application/octet-stream' });

                        var container = document.getElementById('content-zone');
                        container.innerHTML = '';
                        container.style.display = 'block';

                        var renderOptions = {
                            className: 'docx_viewer',
                            inWrapper: false,
                            ignoreWidth: true,
                            ignoreHeight: true,
                            experimental: true,
                            renderHeaders: true,
                            renderFooters: true
                        };

                        await docx.renderAsync(blob, container, null, renderOptions);

                        // Wait for all images to load + browser paint
                        await waitForImages(container);
                        await waitForPaint();

                        var opt = {
                            margin:       0,
                            filename:     data.fileName + '.pdf',
                            image:        { type: 'jpeg', quality: 0.98 },
                            html2canvas:  {
                                scale: 2,
                                useCORS: true,
                                allowTaint: true,
                                letterRendering: true,
                                logging: false,
                                backgroundColor: '#ffffff'
                            },
                            jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' },
                            pagebreak:    { mode: ['css', 'legacy'], avoid: ['p', 'li', 'tr', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'blockquote'] }
                        };

                        var worker = html2pdf().from(container).set(opt);

                        if (data.mode === 'save') {
                            worker.output('arraybuffer').then(function(buffer) {
                                container.style.display = 'none';
                                sendSuccess(buffer, data.fileName);
                            }).catch(function(err) {
                                container.style.display = 'none';
                                sendError('PDF Blob Generation Failed: ' + err.message);
                            });
                        } else {
                            worker.save().then(function() {
                                container.style.display = 'none';
                                sendSuccess();
                            }).catch(function(err) {
                                container.style.display = 'none';
                                sendError('PDF Generation Failed: ' + err.message);
                            });
                        }

                    } catch (e) {
                         sendError('Render Error: ' + e.message);
                    }
                }
            });

            function sendError(msg) {
                if (!parentOrigin) return;
                window.parent.postMessage({ type: 'docgen_error', message: msg }, parentOrigin);
            }

            function sendSuccess(blob, fileName) {
                if (!parentOrigin) return;
                window.parent.postMessage({
                    type: 'docgen_success',
                    blob: blob,
                    fileName: fileName
                }, parentOrigin);
            }
        </script>
    </body>
    </html>
</apex:page>