                    </tr>
                    <tr>
                        <td>Bulk Generation</td>
                        <td class="col-docgen cmp-yes">Built-in</td>
                        <td class="cmp-partial">Add-on cost</td>
                        <td class="cmp-yes">Yes</td>
                        <td class="cmp-partial">Limited</td>
                        <td class="cmp-partial">Higher tiers</td>
