            </table>
        </div>
        <p class="compare-note">Pricing reflects publicly available estimates as of early 2026. Actual pricing varies by contract.</p>
    </section>

    <!-- Help / Lead Capture -->
    <section class="help-section">
        <h2>Need Help Getting Started?</h2>
        <p class="help-subtitle">We'll walk you through setup, templates, and your first document — free.</p>
        <div class="help-form" id="helpForm">
            <div class="form-group">
                <label for="helpName">Name</label>
                <input type="text" id="helpName" placeholder="Jane Smith" />
            </div>
            <div class="form-group">
                <label for="helpEmail">Email</label>
                <input type="email" id="helpEmail" placeholder="jane@company.com" />
            </div>
            <div class="form-group">
                <label for="helpCompany">Company</label>
                <input type="text" id="helpCompany" placeholder="Acme Corp" />
            </div>
            <div class="form-group">
                <label for="helpMessage">How can we help?</label>
                <textarea id="helpMessage" placeholder="I need help setting up templates for our invoices..."></textarea>
            </div>
            <button type="button" class="form-submit" id="helpSubmitBtn" onclick="submitHelpForm()">Send Request</button>
            <div class="form-error" id="helpError"></div>
            <p class="form-fine-print">We'll respond within one business day. No spam, no sales pitch.</p>
        </div>
        <div class="form-success" id="helpSuccess">
            Thank you! We'll be in touch shortly.
        </div>
    </section>

    <!-- Install -->
    <section class="install-section">
        <h2>Install in 30 seconds</h2>
        <p>No configuration needed. Assign the permission set and start generating.</p>
        <div class="install-links">
            <a href="{!installLinkProd}" class="btn btn-primary">Install in Production</a>
            <a href="{!installLinkSandbox}" class="btn btn-secondary" style="color: #1a1a2e; border-color: #cbd5e1;">Install in Sandbox</a>
        </div>
        <div class="install-code">sf package install --package 04tal000006PEabAAG --wait 10 --target-org your-org</div>
        <p style="margin-top: 1.5rem; font-size: 0.9rem;">Then: Assign <strong>DocGen Admin</strong> permission set &bull; Open the <strong>DocGen</strong> app</p>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-links">
            <a href="https://github.com/Portwood-Global-Solutions/Portwood-DocGen">GitHub</a>
            <a href="mailto:hello@portwoodglobalsolutions.com">Support</a>
            <a href="https://github.com/Portwood-Global-Solutions/Portwood-DocGen/issues">Report a Bug</a>
            <a href="/DocGenTerms">Terms of Service</a>
            <a href="/DocGenPrivacy">Privacy Policy</a>
        </div>
        <p>Built by <a href="https://portwoodglobalsolutions.com">Portwood Global Solutions</a></p>
        <p style="margin-top: 0.5rem; font-size: 0.8rem;">Apache 2.0 License &bull; AppExchange listing coming soon</p>
    </footer>

    <script>
        function submitHelpForm() {
            var name = document.getElementById('helpName').value.trim();
            var email = document.getElementById('helpEmail').value.trim();
            var company = document.getElementById('helpCompany').value.trim();
            var message = document.getElementById('helpMessage').value.trim();
            var errEl = document.getElementById('helpError');
            var btn = document.getElementById('helpSubmitBtn');

            errEl.style.display = 'none';

            if (!name || !email) {
                errEl.textContent = 'Please enter your name and email.';
                errEl.style.display = 'block';
                return;
            }
            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                errEl.textContent = 'Please enter a valid email address.';
                errEl.style.display = 'block';
                return;
            }

            btn.disabled = true;
            btn.textContent = 'Sending...';

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenLandingController.submitHelpRequest}',
                name, email, company, message,
                function(result, event) {
                    if (event.status) {
                        document.getElementById('helpForm').style.display = 'none';
                        document.getElementById('helpSuccess').style.display = 'block';
                    } else {
                        errEl.textContent = event.message || 'Something went wrong. Please email hello@portwoodglobalsolutions.com instead.';
                        errEl.style.display = 'block';
                        btn.disabled = false;
                        btn.textContent = 'Send Request';
                    }
                },
                { escape: true }
            );
        }
    </script>

</body>
</html>
</apex:page>
