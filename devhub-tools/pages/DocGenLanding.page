    <!-- Community -->
    <section class="help-section">
        <h2>Join the Community</h2>
        <p class="help-subtitle">Ask questions, request features, share templates, and help shape the roadmap.</p>
        <div style="max-width: 800px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem;">
            <div class="feature-card" style="text-align: center;">
                <div class="feature-icon">&#128172;</div>
                <h3>Discussion Board</h3>
                <p>Get help, share tips, and connect with other DocGen users and admins.</p>
                <a href="/DocGenCommunity" class="btn btn-primary" style="margin-top: 1rem; display: inline-block; padding: 10px 24px; font-size: 0.9rem;">Join Discussions</a>
            </div>
            <div class="feature-card" style="text-align: center;">
                <div class="feature-icon">&#128161;</div>
                <h3>Feature Requests</h3>
                <p>Vote on what gets built next. The community drives the roadmap.</p>
                <a href="/DocGenRoadmap" class="btn btn-primary" style="margin-top: 1rem; display: inline-block; padding: 10px 24px; font-size: 0.9rem;">View Roadmap</a>
            </div>
            <div class="feature-card" style="text-align: center;">
                <div class="feature-icon">&#128027;</div>
