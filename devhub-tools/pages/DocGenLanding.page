                        <td>Industries license req'd</td>
                        <td>~$25-150/org/mo</td>
                        <td>~$35-65/user/mo</td>
                        <td>~$25-35/user/mo</td>
                    </tr>
                    <tr>
                        <td>100% Native Salesforce</td>
                        <td class="col-docgen cmp-yes">Yes</td>
                        <td class="cmp-no">No</td>
                        <td class="cmp-yes">Yes</td>
                        <td class="cmp-partial">Partial</td>
                        <td class="cmp-yes">Yes</td>
                        <td class="cmp-no">No</td>
                        <td class="cmp-no">No</td>
                    </tr>
                    <tr>
                        <td>Data Stays in Org</td>
                        <td class="col-docgen cmp-yes">Yes</td>
                        <td class="cmp-no">No</td>
                        <td class="cmp-yes">Yes</td>
                        <td class="cmp-yes">Yes</td>
