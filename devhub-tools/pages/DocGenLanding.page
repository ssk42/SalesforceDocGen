        }
        .footer a { color: #60a5fa; text-decoration: none; }
        .footer a:hover { text-decoration: underline; }
        .footer-links { margin-bottom: 1rem; }
        .footer-links a { margin: 0 1rem; font-size: 0.9rem; }

        /* Hero Map */
        .hero-map {
            max-width: 1000px;
