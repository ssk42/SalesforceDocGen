<apex:page controller="DocGenLandingController" showHeader="false" standardStylesheets="false" sidebar="false" applyHtmlTag="true" applyBodyTag="false" docType="html-5.0" cache="true">
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Portwood DocGen — Free Document Generation for Salesforce</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: #1a1a2e;
            background: #f8fafc;
            line-height: 1.6;
        }

        /* Header */
        .header {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: #fff;
            padding: 1rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .logo {
            font-size: 1.25rem;
            font-weight: 700;
            letter-spacing: -0.5px;
        }
        .logo span { color: #60a5fa; }
        .header-links a {
            color: #94a3b8;
            text-decoration: none;
            margin-left: 1.5rem;
            font-size: 0.9rem;
            font-weight: 500;
        }
        .header-links a:hover { color: #fff; }

        /* Hero */
        .hero {
            background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%);
            color: #fff;
            text-align: center;
            padding: 5rem 2rem 4rem;
        }
        .hero h1 {
            font-size: 3rem;
            font-weight: 800;
            letter-spacing: -1px;
            margin-bottom: 1rem;
            line-height: 1.1;
        }
        .hero h1 span { color: #60a5fa; }
        .hero p {
            font-size: 1.25rem;
            color: #94a3b8;
            max-width: 700px;
            margin: 0 auto 2.5rem;
        }
        .hero-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }
        .btn {
            display: inline-block;
            padding: 14px 32px;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: 700;
            text-decoration: none;
            transition: transform 0.2s, box-shadow 0.2s;
            cursor: pointer;
            border: none;
        }
        .btn:hover { transform: translateY(-2px); }
        .btn-primary {
            background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
            color: #fff;
            box-shadow: 0 4px 14px rgba(37, 99, 235, 0.3);
        }
        .btn-secondary {
            background: rgba(255,255,255,0.1);
            color: #fff;
            border: 2px solid rgba(255,255,255,0.2);
        }
        .btn-secondary:hover { background: rgba(255,255,255,0.15); }
        .btn-demo {
            background: linear-gradient(135deg, #059669 0%, #047857 100%);
            color: #fff;
            box-shadow: 0 4px 14px rgba(5, 150, 105, 0.3);
        }

        /* Badge */
        .badge-row {
            display: flex;
            gap: 0.75rem;
            justify-content: center;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }
        .badge {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            padding: 6px 16px;
            border-radius: 50px;
            font-size: 0.8rem;
            color: #94a3b8;
            font-weight: 600;
        }
        .badge.green { color: #4ade80; border-color: rgba(74, 222, 128, 0.2); }

        /* Features */
        .features {
            padding: 5rem 2rem;
            max-width: 1100px;
            margin: 0 auto;
        }
        .features h2 {
            text-align: center;
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 3rem;
        }
        .feature-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }
        .feature-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 2rem;
            transition: box-shadow 0.2s;
        }
        .feature-card:hover { box-shadow: 0 8px 25px rgba(0,0,0,0.08); }
        .feature-card h3 {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }
        .feature-card p {
            color: #64748b;
            font-size: 0.95rem;
        }
        .feature-icon {
            font-size: 2rem;
            margin-bottom: 1rem;
        }

        /* Comparison */
        .compare-section {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: #fff;
            padding: 5rem 2rem;
        }
        .compare-section h2 {
            text-align: center;
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0.75rem;
        }
        .compare-subtitle {
            text-align: center;
            color: #94a3b8;
            font-size: 1.1rem;
            margin-bottom: 3rem;
        }
        .compare-table-wrap {
            max-width: 1100px;
            margin: 0 auto;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }
        .compare-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }
        .compare-table th, .compare-table td {
            padding: 10px 14px;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            white-space: nowrap;
        }
        .compare-table th {
            background: rgba(255,255,255,0.05);
            font-weight: 700;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #94a3b8;
        }
        .compare-table th.col-docgen {
            color: #60a5fa;
            background: rgba(96,165,250,0.08);
        }
        .compare-table td:first-child {
            text-align: left;
            font-weight: 600;
            color: #e2e8f0;
        }
        .compare-table td.col-docgen {
            background: rgba(96,165,250,0.04);
            color: #fff;
            font-weight: 600;
        }
        .compare-table td { color: #94a3b8; }
        .cmp-yes { color: #4ade80 !important; }
        .cmp-no { color: #64748b !important; }
        .cmp-partial { color: #fbbf24 !important; }
        .compare-note {
            text-align: center;
            color: #64748b;
            font-size: 0.8rem;
            margin-top: 1.5rem;
        }

        /* Install */
        .install-section {
            background: #fff;
            border-top: 1px solid #e2e8f0;
            border-bottom: 1px solid #e2e8f0;
            padding: 4rem 2rem;
            text-align: center;
        }
        .install-section h2 { font-size: 2rem; font-weight: 800; margin-bottom: 1rem; }
        .install-section p { color: #64748b; margin-bottom: 2rem; font-size: 1.1rem; }
        .install-links {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }
        .install-code {
            background: #0f172a;
            color: #e2e8f0;
            padding: 12px 24px;
            border-radius: 8px;
            font-family: 'Courier New', monospace;
            font-size: 0.85rem;
            display: inline-block;
            margin-top: 1rem;
        }

        /* Community Section */
        .help-section {
            background: #f8fafc;
            padding: 5rem 2rem;
        }
        .help-section h2 {
            text-align: center;
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: #1a1a2e;
        }
        .help-subtitle {
            text-align: center;
            color: #64748b;
            font-size: 1.1rem;
            margin-bottom: 2.5rem;
        }

        /* Footer */
        .footer {
            background: #0f172a;
            color: #94a3b8;
            padding: 3rem 2rem;
            text-align: center;
        }
        .footer a { color: #60a5fa; text-decoration: none; }
        .footer a:hover { text-decoration: underline; }
        .footer-links { margin-bottom: 1rem; }
        .footer-links a { margin: 0 1rem; font-size: 0.9rem; }

        /* Responsive */
        @media (max-width: 640px) {
            .hero h1 { font-size: 2rem; }
            .hero p { font-size: 1rem; }
            .header { flex-direction: column; gap: 0.5rem; }
            .header-links a { margin-left: 0.75rem; }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header class="header">
        <div class="logo">Portwood <span>DocGen</span></div>
        <nav class="header-links">
            <a href="/DocGenCommunity">Community</a>
            <a href="/DocGenSupport">Support</a>
            <a href="/DocGenRoadmap">Roadmap</a>
            <a href="https://github.com/Portwood-Global-Solutions/Portwood-DocGen">GitHub</a>
            <a href="{!installLinkProd}" style="color: #60a5fa;">Install</a>
        </nav>
    </header>

    <!-- Hero -->
    <section class="hero">
        <div class="badge-row">
            <span class="badge green">100% Free Forever</span>
            <span class="badge">100% Native Salesforce</span>
            <span class="badge">Your Data Never Leaves Your Org</span>
            <span class="badge green">Open Source</span>
            <apex:outputPanel rendered="{!installCount > 0}">
                <span class="badge green">Proudly serving {!installCount} org{!IF(installCount > 1, 's', '')}</span>
            </apex:outputPanel>
        </div>
        <h1>Document Generation<br/>for <span>Salesforce</span></h1>
        <p>Generate polished PDFs and Word documents from any Salesforce record. Pull in related records, images, barcodes, totals, and more — all from a simple Word template.</p>
        <div class="hero-actions">
            <a href="{!installLinkProd}" class="btn btn-primary">Install Free</a>
            <a href="{!installLinkSandbox}" class="btn btn-secondary">Install in Sandbox</a>
            <apex:outputPanel rendered="{!NOT(ISBLANK(demoUrl))}">
                <a href="{!HTMLENCODE(demoUrl)}" target="_blank" class="btn btn-demo">Live Demo</a>
            </apex:outputPanel>
        </div>
    </section>

    <!-- Features -->
    <section class="features">
        <h2>Everything you need. Nothing you don't.</h2>
        <div class="feature-grid">
            <div class="feature-card">
                <div class="feature-icon">&#128196;</div>
                <h3>PDF &amp; Word Output</h3>
                <p>Generate professional PDFs and Word documents from your own branded Word templates. Just add placeholder tags and upload.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">&#128257;</div>
                <h3>Point-and-Click Setup</h3>
                <p>Visual query builder lets you pick fields and related records without writing any code. Works with any standard or custom object.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">&#128248;</div>
                <h3>Images &amp; Barcodes</h3>
                <p>Embed logos, photos, and images from your Salesforce records. Add Code 128 barcodes and QR codes to PDFs.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">&#9889;</div>
                <h3>Automate with Flows</h3>
                <p>Trigger document generation from Salesforce Flows — auto-generate invoices, contracts, or reports when records change. Sample Flows included.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">&#128218;</div>
                <h3>Bulk Generation</h3>
                <p>Generate documents for hundreds of records at once from list views or reports. Perfect for batch invoicing, statements, and mail merges.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">&#128274;</div>
                <h3>Secure &amp; Reliable</h3>
                <p>100% native — your data never leaves Salesforce. Respects all sharing rules and field-level security. Tested at scale with 10,000+ row documents.</p>
            </div>
        </div>
    </section>

