            .header { flex-direction: column; gap: 0.5rem; }
            .header-links a { margin-left: 0.75rem; }
            .hero-map { margin-left: -2rem; margin-right: -2rem; max-width: none; }
            #docgen-map { height: 260px; border-radius: 0; box-shadow: none; }
            .hero-map-label { font-size: 0.8rem; }
            .modal { padding: 1.5rem; width: 95%; }
