/* Populate country dropdown from the same list */
(function() {
    var sel = document.getElementById('install-country');
    var names = Object.keys(CC).sort();
    for (var i = 0; i < names.length; i++) {
        var opt = document.createElement('option');
        opt.value = names[i];
        opt.textContent = names[i];
        sel.appendChild(opt);
    }
})();

/* UTM params — captured once on page load */
var UTM = (function() {
    var params = new URLSearchParams(window.location.search);
    return {
        source: params.get('utm_source') || '',
        medium: params.get('utm_medium') || '',
        campaign: params.get('utm_campaign') || '',
        content: params.get('utm_content') || '',
        term: params.get('utm_term') || ''
    };
})();

/* Modal */
function openInstallModal() {
    document.getElementById('install-modal').classList.add('active');
    document.body.style.overflow = 'hidden';
}
function closeInstallModal() {
    document.getElementById('install-modal').classList.remove('active');
    document.body.style.overflow = '';
}
document.getElementById('install-modal').addEventListener('click', function(e) {
    if (e.target === this) closeInstallModal();
});

/* Install form submission */
function submitInstallForm() {
    var company = document.getElementById('install-company').value.trim();
    var industry = document.getElementById('install-industry').value;
    var country = document.getElementById('install-country').value;
    var email = document.getElementById('install-email').value.trim();
    var errEl = document.getElementById('install-error');

    if (!company || !industry || !country) {
        errEl.textContent = 'Please fill in all required fields.';
        errEl.style.display = 'block';
        return;
    }
    errEl.style.display = 'none';

    var btn = document.getElementById('install-submit');
    btn.disabled = true;
    btn.textContent = 'Processing...';

    Visualforce.remoting.Manager.invokeAction(
        '{!$RemoteAction.DocGenLandingController.submitInstallLead}',
        company, industry, country, email,
        UTM.source, UTM.medium, UTM.campaign, UTM.content, UTM.term,
        function(result, event) {
            if (event.status) {
                document.getElementById('modal-form').style.display = 'none';
                document.getElementById('modal-success').style.display = 'block';
            } else {
                errEl.textContent = event.message || 'Something went wrong. Please try again.';
                errEl.style.display = 'block';
                btn.disabled = false;
                btn.textContent = 'Get Install Links';
            }
        },
        { escape: true }
    );
}

/* Leaflet map */
function initMap() {
    var isMobile = window.innerWidth <= 640;
    var map = L.map('docgen-map', {
        center: [20, 0],
        zoom: isMobile ? 1 : 2,
        scrollWheelZoom: false,
        attributionControl: true,
        dragging: !L.Browser.mobile,
        tap: false
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}.png', {
        attribution: '\u0026copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> \u0026copy; <a href="https://carto.com/">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 18
    }).addTo(map);

    Visualforce.remoting.Manager.invokeAction(
        '{!$RemoteAction.DocGenLandingController.getInstallMapData}',
        function(result, event) {
            if (!event.status || !result) return;

            var countryCount = result.length;
            if (countryCount > 0) {
                document.getElementById('map-subtitle').textContent =
                    'Reducing document generation costs across ' + countryCount + ' countr' + (countryCount === 1 ? 'y' : 'ies') + ' and counting';
            }

            for (var i = 0; i < result.length; i++) {
                var coords = CC[result[i].country];
                if (!coords) continue;
                var r = Math.max(8, Math.min(30, Math.sqrt(result[i].count) * 6));
                L.circleMarker(coords, {
                    radius: r,
                    fillColor: '#2563eb',
                    fillOpacity: 0.7,
                    color: '#1d4ed8',
                    weight: 2
                }).addTo(map).bindPopup(
                    '<strong>' + result[i].country + '</strong><br/>' +
                    result[i].count + ' installation' + (result[i].count > 1 ? 's' : '')
                );
            }
        },
        { escape: true }
    );
}

initMap();
