        }
        #docgen-map { height: 380px; border-radius: 12px; overflow: hidden; box-shadow: 0 8px 30px rgba(0,0,0,0.3); }

        /* Install Form */
        .install-form {
            max-width: 480px;
            margin: 0 auto;
            text-align: left;
        }
        .install-form label {
            display: block;
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 0.35rem;
            color: #1a1a2e;
        }
        .install-form input,
        .install-form select {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            font-size: 0.95rem;
            margin-bottom: 1rem;
            font-family: inherit;
            background: #fff;
            color: #1a1a2e;
        }
        .install-form input:focus,
        .install-form select:focus {
            outline: none;
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }
        .install-form .optional-label {
