<apex:page showHeader="false" standardStylesheets="false" sidebar="false" applyHtmlTag="true" applyBodyTag="false" docType="html-5.0" cache="true">
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Support the Project — Portwood DocGen</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #e2e8f0; background: #0f172a; line-height: 1.7; }
        a { color: #60a5fa; text-decoration: none; } a:hover { text-decoration: underline; }

        /* Header */
        .header { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border-bottom: 1px solid rgba(255,255,255,0.06); padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; }
        .logo { font-size: 1.25rem; font-weight: 700; letter-spacing: -0.5px; color: #fff; text-decoration: none; } .logo span { color: #60a5fa; }
        .header-links a { color: #94a3b8; margin-left: 1.5rem; font-size: 0.9rem; font-weight: 500; text-decoration: none; } .header-links a:hover { color: #fff; }

        /* Hero */
        .hero { background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%); text-align: center; padding: 5rem 2rem 4rem; }
        .hero h1 { font-size: 2.75rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 1rem; line-height: 1.1; color: #fff; }
        .hero h1 em { font-style: normal; color: #60a5fa; }
        .hero p { font-size: 1.15rem; color: #94a3b8; max-width: 720px; margin: 0 auto 1.5rem; }
        .hero-badge { display: inline-block; background: rgba(74, 222, 128, 0.1); border: 1px solid rgba(74, 222, 128, 0.25); color: #4ade80; padding: 8px 24px; border-radius: 50px; font-size: 0.95rem; font-weight: 700; margin-bottom: 2rem; }

        /* Section */
        .section { max-width: 900px; margin: 0 auto; padding: 4rem 2rem; }
        .section h2 { font-size: 2rem; font-weight: 800; text-align: center; margin-bottom: 0.5rem; color: #fff; }
        .section .subtitle { text-align: center; color: #64748b; margin-bottom: 2.5rem; font-size: 1.05rem; }

        /* About */
        .about-grid { display: grid; grid-template-columns: 300px 1fr; gap: 3rem; align-items: start; }
        .about-photo { width: 100%; border-radius: 16px; border: 3px solid rgba(96, 165, 250, 0.2); }
        .about-photo-placeholder { width: 100%; aspect-ratio: 3/4; border-radius: 16px; border: 3px solid rgba(96, 165, 250, 0.2); background: #1e293b; display: flex; align-items: center; justify-content: center; color: #475569; font-size: 0.9rem; text-align: center; padding: 2rem; }
        .about-content h3 { font-size: 1.4rem; font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
        .about-content p { color: #cbd5e1; margin-bottom: 1rem; font-size: 0.95rem; }
        .about-content .highlight { color: #60a5fa; font-weight: 600; }
        .cert-badges { display: flex; gap: 0.5rem; flex-wrap: wrap; margin: 1rem 0; }
        .cert-badge { background: rgba(96, 165, 250, 0.1); border: 1px solid rgba(96, 165, 250, 0.2); color: #60a5fa; padding: 4px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 600; }

        /* Philosophy */
        .philosophy { background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); border-radius: 16px; padding: 2.5rem; margin-bottom: 3rem; border: 1px solid rgba(255,255,255,0.06); }
        .philosophy h3 { font-size: 1.3rem; font-weight: 800; color: #fff; margin-bottom: 1rem; }
        .philosophy p { color: #cbd5e1; margin-bottom: 1rem; font-size: 0.95rem; }
        .philosophy .pull-quote { font-size: 1.2rem; font-weight: 700; color: #4ade80; border-left: 4px solid #4ade80; padding-left: 1.25rem; margin: 1.5rem 0; line-height: 1.4; }

        /* Featured Nonprofit */
        .nonprofit-section { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); padding: 4rem 2rem; }
        .nonprofit-card { max-width: 900px; margin: 0 auto; background: #1e293b; border: 2px solid rgba(251, 191, 36, 0.2); border-radius: 16px; overflow: hidden; }
        .nonprofit-header { background: linear-gradient(135deg, #92400e 0%, #78350f 100%); padding: 1.5rem 2rem; }
        .nonprofit-header .label { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #fbbf24; margin-bottom: 0.25rem; }
        .nonprofit-header h3 { font-size: 1.5rem; font-weight: 800; color: #fff; }
        .nonprofit-body { padding: 2rem; }
        .nonprofit-body p { color: #cbd5e1; margin-bottom: 1rem; font-size: 0.95rem; }
        .nonprofit-stat { display: inline-block; background: rgba(251, 191, 36, 0.1); border: 1px solid rgba(251, 191, 36, 0.2); color: #fbbf24; padding: 6px 18px; border-radius: 50px; font-size: 0.85rem; font-weight: 700; margin-right: 0.5rem; margin-bottom: 0.5rem; }
        .nonprofit-link { display: inline-block; margin-top: 1rem; background: #fbbf24; color: #1a1a2e; padding: 12px 28px; border-radius: 50px; font-weight: 700; text-decoration: none; font-size: 0.95rem; transition: transform 0.2s; }
        .nonprofit-link:hover { transform: translateY(-2px); text-decoration: none; }

        /* Split callout */
        .split-callout { max-width: 900px; margin: 2.5rem auto 0; background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); border: 2px solid rgba(96, 165, 250, 0.15); border-radius: 16px; padding: 2.5rem; text-align: center; }
        .split-callout h3 { font-size: 1.3rem; font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
        .split-callout p { color: #94a3b8; font-size: 1rem; max-width: 650px; margin: 0 auto 1.5rem; }
        .split-visual { display: flex; align-items: center; justify-content: center; gap: 1.5rem; margin: 2rem 0 1rem; flex-wrap: wrap; }
        .split-box { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 1.25rem 2rem; text-align: center; min-width: 200px; }
        .split-box .label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; color: #64748b; font-weight: 600; }
        .split-box .name { font-size: 1.1rem; font-weight: 700; margin-top: 0.25rem; }
        .split-box.docgen .name { color: #60a5fa; }
        .split-box.nonprofit .name { color: #fbbf24; }
        .split-arrow { font-size: 1.5rem; color: #475569; }

        /* Support CTA */
        .support-cta { text-align: center; padding: 4rem 2rem; background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%); }
        .support-cta h2 { font-size: 2rem; font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
        .support-cta p { color: #94a3b8; max-width: 600px; margin: 0 auto 2rem; font-size: 1.05rem; }
        .btn-coffee { display: inline-block; background: linear-gradient(135deg, #FFDD00 0%, #FBB034 100%); color: #1a1a2e; padding: 16px 40px; border-radius: 50px; font-size: 1.1rem; font-weight: 800; text-decoration: none; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 14px rgba(251, 176, 52, 0.3); }
        .btn-coffee:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(251, 176, 52, 0.4); text-decoration: none; }

        /* Footer */
        .footer { border-top: 1px solid rgba(255,255,255,0.06); padding: 2rem; text-align: center; color: #475569; font-size: 0.8rem; }
        .footer a { color: #60a5fa; }
        .footer-links { margin-bottom: 0.75rem; }
        .footer-links a { margin: 0 0.75rem; }

        @media (max-width: 768px) {
            .hero h1 { font-size: 2rem; }
            .about-grid { grid-template-columns: 1fr; }
            .about-photo-placeholder { max-width: 300px; margin: 0 auto; }
            .header { flex-direction: column; gap: 0.5rem; }
            .header-links a { margin-left: 0.75rem; }
            .split-visual { flex-direction: column; }
            .split-arrow { transform: rotate(90deg); }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header class="header">
        <a href="/DocGenLanding" class="logo">Portwood <span>DocGen</span></a>
        <nav class="header-links">
            <a href="/DocGenLanding">Home</a>
            <a href="/DocGenGuide">User Guide</a>
            <a href="/DocGenRoadmap">Roadmap</a>
            <a href="/DocGenCommunity">Community</a>
            <a href="https://github.com/Portwood-Global-Solutions/Portwood-DocGen">GitHub</a>
            <a href="/DocGenSupport" style="color: #fbbf24;">Support the Project</a>
        </nav>
    </header>

    <!-- Hero -->
    <section class="hero">
        <div class="hero-badge">Pay What You Can</div>
        <h1>Support the <em>Project</em></h1>
        <p>DocGen is free because every nonprofit, every small business, and every org deserves great document generation. Whether you can pay or not, the product is yours. If you're able to give back, here's how a little goes a long way.</p>
    </section>

    <!-- Philosophy -->
    <section class="section">
        <div class="philosophy">
            <h3>Pay What You Can</h3>
            <p>We know DocGen is a huge cost savings for your org. We want that to benefit <em>you</em>.</p>
            <p>Every nonprofit needs this product. Every business needs this product. Not all of them can afford to pay. <strong>That's okay.</strong></p>
            <div class="pull-quote">A little can go a really long way when you know how to use it.</div>
            <p>We have our own causes we support, and we try to be good stewards of our money. That's why we keep DocGen free, lean, and focused. No venture capital. No investor pressure to monetize users. Just a product that works, built by people who care.</p>
            <p>If you're in a position to give back, we're grateful. If you're not, that's perfectly fine. Use DocGen, build great things with it, and tell others about it. That's support too.</p>
        </div>
    </section>

    <!-- Featured Nonprofit -->
    <section class="nonprofit-section">
        <div style="max-width: 900px; margin: 0 auto; text-align: center; margin-bottom: 2.5rem;">
            <h2 style="color: #fff; font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem;">Featured Nonprofit</h2>
            <p style="color: #64748b; font-size: 1.05rem;">We call out foundations we believe in, highlight how they're making an impact, and bring attention to their causes.</p>
        </div>

        <div class="nonprofit-card">
            <div class="nonprofit-header">
                <div class="label">Featured Partner</div>
                <h3>Circles Indy</h3>
            </div>
            <div class="nonprofit-body">
                <p>Circles Indy is a community-driven program in Indianapolis working to increase upward mobility for individuals and families in poverty. Based on the national Circles USA model, they build intentional relationships between Circle Leaders (individuals and families moving out of poverty) and Circle Allies (volunteers who come alongside them to provide support, encouragement, and expanded social networks).</p>
                <p>The model works. After 18 months in the program, participants see an average <strong style="color: #4ade80;">71% increase in their income</strong> and a measurable increase in the number of people they can call on for support.</p>
                <div>
                    <span class="nonprofit-stat">Indianapolis, IN</span>
                    <span class="nonprofit-stat">Poverty Reduction</span>
                    <span class="nonprofit-stat">Community-Driven</span>
                    <span class="nonprofit-stat">Small but Mighty</span>
                </div>
                <p style="margin-top: 1.25rem; color: #94a3b8; font-size: 0.9rem;">Circles Indy is sponsored by BRiCKs Alliance, Inc., a nonprofit focused on building intentional, cross-community friendships that equip and inspire families to permanently move out of poverty and thrive.</p>
                <a href="https://www.circlesindy.org/donate" class="nonprofit-link" target="_blank">Donate to Circles Indy</a>
            </div>
        </div>

        <!-- Split your support -->
        <div class="split-callout">
            <h3>Split Your Support</h3>
            <p>If you're thinking about supporting our project, we ask that whatever you were thinking about giving, split it with our featured nonprofit. They are small but mighty.</p>
            <div class="split-visual">
                <div class="split-box docgen">
                    <div class="label">Half to</div>
                    <div class="name">Portwood DocGen</div>
                </div>
                <div class="split-arrow">+</div>
                <div class="split-box nonprofit">
                    <div class="label">Half to</div>
                    <div class="name">Circles Indy</div>
                </div>
            </div>
            <p style="font-size: 0.85rem; color: #475569; margin-bottom: 0;">Two causes. One act of generosity. Twice the impact.</p>
        </div>
    </section>

    <!-- Support CTA -->
    <section class="support-cta">
        <h2>Support DocGen</h2>
        <p>Every dollar helps keep DocGen free, maintained, and improving. No amount is too small.</p>
        <a href="https://buymeacoffee.com/portwooddocgen" class="btn-coffee">
            Buy Us a Coffee
        </a>
        <p style="margin-top: 1.5rem; font-size: 0.85rem; color: #475569;">And don't forget, <a href="https://www.circlesindy.org/donate" target="_blank">send the other half to Circles Indy</a>.</p>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-links">
            <a href="/DocGenLanding">Home</a>
            <a href="/DocGenCommunity">Community</a>
            <a href="/DocGenRoadmap">Roadmap</a>
            <a href="https://github.com/Portwood-Global-Solutions/Portwood-DocGen">GitHub</a>
            <a href="/DocGenTerms">Terms</a>
            <a href="/DocGenPrivacy">Privacy</a>
        </div>
        <p>Built by <a href="https://portwoodglobalsolutions.com">Portwood Global Solutions</a></p>
    </footer>

</body>
</html>
</apex:page>
