    <!-- ═══ EDIT POST MODAL ═══ -->
    <div id="editModal" class="modal-overlay" style="display: none;">
        <div class="modal-card">
            <h2 style="font-size: 1.25rem; font-weight: 800; color: #fff; margin-bottom: 1.25rem;">Edit Post</h2>
            <div class="form-group">
                <label>Title</label>
                <input type="text" id="editTitle" class="form-input" />
            </div>
            <div class="form-group">
                <label>Body</label>
                <div class="rte-toolbar">
                    <button type="button" onclick="rteCmd('bold')" title="Bold"><b>B</b></button>
                    <button type="button" onclick="rteCmd('italic')" title="Italic"><i>I</i></button>
                    <button type="button" onclick="rteCmd('underline')" title="Underline"><u>U</u></button>
                    <div class="sep"></div>
                    <button type="button" onclick="rteCmd('insertUnorderedList')" title="Bullet List">&#8226; List</button>
                    <button type="button" onclick="rteCmd('formatBlock', 'blockquote')" title="Quote">&ldquo; Quote</button>
                    <button type="button" onclick="rteInsertCode()" title="Code Block">&lt;/&gt; Code</button>
                    <div class="sep"></div>
                    <button type="button" onclick="rteInsertLink()" title="Insert Link">Link</button>
                </div>
                <div class="rte-editor" id="editBody" contenteditable="true" style="max-height: 50vh;"></div>
            </div>
            <div class="form-error" id="editError"></div>
            <div style="display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 1rem;">
                <button type="button" class="btn btn-ghost" onclick="closeEditModal()">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveEditPost()">Save Changes</button>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <p>Built on Salesforce by <a href="https://portwoodglobalsolutions.com">Portwood Global Solutions</a></p>
    </footer>

    <div class="mention-dropdown" id="mentionDropdown"></div>

    <!-- ═══ JavaScript ═══ -->
    <script>
        var sessionToken = '{!JSENCODE(sessionToken)}';

        function getCookie(name) {
            var v = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
            return v ? v.pop() : '';
        }
        function setCookie(name, value, days) {
            var d = new Date(); d.setTime(d.getTime() + days * 86400000);
            document.cookie = name + '=' + value + ';expires=' + d.toUTCString() + ';path=/;secure';
        }

        // ─── Auth ───
        function doSignup() {
            var email = document.getElementById('signupEmail').value.trim();
            var errEl = document.getElementById('signupError');
            var succEl = document.getElementById('signupSuccess');
            errEl.textContent = ''; succEl.style.display = 'none';
            var params = new URLSearchParams(window.location.search);
            var orgId = params.get('orgId') || '';

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.register}', email, orgId,
                function(result, event) {
                    if (event.status) {
                        if (result === 'already_registered') {
                            errEl.textContent = '';
                            succEl.textContent = 'You already have an account! Redirecting to login...';
                            succEl.style.display = 'block';
                            setTimeout(function() { window.location.href = '/DocGenCommunity?view=login'; }, 2000);
                        } else {
                            document.getElementById('signupBtn').style.display = 'none';
                            succEl.textContent = 'Verification email sent! Check your inbox and click the link.';
                            succEl.style.display = 'block';
                        }
                    } else {
                        errEl.textContent = event.message;
                    }
                }, {escape: true}
            );
        }

        function doLogin() {
            var email = document.getElementById('loginEmail').value.trim();
            var password = document.getElementById('loginPassword').value;
            var errEl = document.getElementById('loginError');
            errEl.textContent = '';

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.login}', email, password,
                function(result, event) {
                    if (event.status) {
                        window.location.href = '/DocGenCommunity?view=setSession&s=' + result;
                    } else {
                        errEl.textContent = event.message;
                    }
                }, {escape: true}
            );
        }

        function doCompleteProfile() {
            var name = document.getElementById('cpName').value.trim();
            var company = document.getElementById('cpCompany').value.trim();
            var password = document.getElementById('cpPassword').value;
            var errEl = document.getElementById('cpError');
            errEl.textContent = '';
            var params = new URLSearchParams(window.location.search);
            var token = params.get('token');
            var orgId = params.get('orgId') || '';

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.completeProfileWithOrg}', token, name, company, password, orgId,
                function(result, event) {
                    if (event.status) {
                        window.location.href = '/DocGenCommunity?view=setSession&s=' + result;
                    } else {
                        errEl.textContent = event.message;
                    }
                }, {escape: true}
            );
        }

        // ─── Rich Text Editor ───
        function rteCmd(cmd, val) { document.execCommand(cmd, false, val || null); }
        function rteInsertLink() {
            var url = prompt('Enter URL:');
            if (url) document.execCommand('createLink', false, url);
        }
        function rteInsertCode() {
            var sel = window.getSelection();
            var text = sel.toString() || 'code here';
            document.execCommand('insertHTML', false, '<pre><code>' + text.replace(/</g, '&lt;') + '</code></pre>');
        }
        function getEditorHtml(id) {
            var el = document.getElementById(id);
            return el ? el.innerHTML.trim() : '';
        }

        // ─── Paste image handler for contenteditable ───
        function handlePasteImage(e) {
            var items = (e.clipboardData || e.originalEvent.clipboardData).items;
            for (var i = 0; i < items.length; i++) {
                if (items[i].type.indexOf('image') === 0) {
                    e.preventDefault();
                    var file = items[i].getAsFile();
                    var reader = new FileReader();
                    var editorId = e.target.id;
                    reader.onload = function(ev) {
                        var base64 = ev.target.result.split(',')[1];
                        var fileName = 'pasted-image-' + Date.now() + '.png';
                        var editor = document.getElementById(editorId);
                        // Show inline preview immediately using the local data URI
                        var placeholderId = 'img-' + Date.now();
                        editor.focus();
                        document.execCommand('insertHTML', false,
                            '<img id="' + placeholderId + '" src="' + ev.target.result + '" alt="Uploading..." style="max-width:100%;border-radius:8px;opacity:0.6;" />');
                        // Upload and replace with public URL
                        Visualforce.remoting.Manager.invokeAction(
                            '{!$RemoteAction.DocGenCommunityController.uploadFile}',
                            sessionToken, fileName, base64, null,
                            function(result, event) {
                                var placeholder = document.getElementById(placeholderId);
                                if (event.status && placeholder) {
                                    placeholder.src = result;
                                    placeholder.alt = fileName;
                                    placeholder.style.opacity = '1';
                                    placeholder.removeAttribute('id');
                                } else if (placeholder) {
                                    placeholder.alt = 'Upload failed';
                                    placeholder.style.opacity = '0.3';
                                }
                            }, {escape: true, buffer: false}
                        );
                    };
                    reader.readAsDataURL(file);
                    return;
                }
            }
        }
        // Attach paste handler to all rich text editors after page loads
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.rte-editor').forEach(function(editor) {
                editor.addEventListener('paste', handlePasteImage);
            });
        });

        // ─── Posts ───
        function doCreatePost() {
            var title = document.getElementById('npTitle').value.trim();
            var body = getEditorHtml('npBody');
            var category = document.getElementById('npCategory').value;
            var topics = document.getElementById('npTopics').value.trim();
            var errEl = document.getElementById('npError');
            errEl.textContent = '';

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.createPost}', sessionToken, title, body, category, topics,
                function(result, event) {
                    if (event.status) {
                        if (mentionState.mentionedIds.length > 0) {
                            Visualforce.remoting.Manager.invokeAction(
                                '{!$RemoteAction.DocGenCommunityController.notifyMentionedUsers}',
                                sessionToken, result, mentionState.mentionedIds.join(','),
                                function() {}, {escape: true}
                            );
                        }
                        window.location.href = '/DocGenCommunity?view=post&id=' + result;
                    } else {
                        errEl.textContent = event.message;
                    }
                }, {escape: true}
            );
        }

        function submitReply(postId) {
            var body = getEditorHtml('replyBody');
            if (!body || body === '<br>') return;

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.createReply}', sessionToken, postId, body,
                function(result, event) {
                    if (event.status) {
                        if (mentionState.mentionedIds.length > 0) {
                            var pId = window.location.search.match(/id=([^&]+)/);
                            Visualforce.remoting.Manager.invokeAction(
                                '{!$RemoteAction.DocGenCommunityController.notifyMentionedUsers}',
                                sessionToken, pId ? pId[1] : '', mentionState.mentionedIds.join(','),
                                function() {}, {escape: true}
                            );
                            mentionState.mentionedIds = [];
                        }
                        window.location.reload();
                    } else {
                        alert(event.message);
                    }
                }, {escape: true}
            );
        }

        // ─── Edit / Delete Post ───
        var editingPostId = null;
        function startEditPost(title, postId) {
            editingPostId = postId;
            document.getElementById('editTitle').value = title;
            // Copy the current post body HTML into the edit editor
            var postBody = document.querySelector('.post-body');
            document.getElementById('editBody').innerHTML = postBody ? postBody.innerHTML : '';
            document.getElementById('editError').textContent = '';
            document.getElementById('editModal').style.display = 'flex';
        }
        function closeEditModal() {
            document.getElementById('editModal').style.display = 'none';
            editingPostId = null;
        }
        function saveEditPost() {
            var title = document.getElementById('editTitle').value.trim();
            var body = getEditorHtml('editBody');
            var errEl = document.getElementById('editError');
            errEl.textContent = '';
            if (!title || !body) { errEl.textContent = 'Title and body are required.'; return; }

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.editPost}', sessionToken, editingPostId, title, body,
                function(result, event) {
                    if (event.status) {
                        window.location.reload();
                    } else {
                        errEl.textContent = event.message;
                    }
                }, {escape: true}
            );
        }
        function confirmDeletePost(postId) {
            if (!confirm('Are you sure you want to delete this post? This cannot be undone.')) return;
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.deletePost}', sessionToken, postId,
                function(result, event) {
                    if (event.status) {
                        window.location.href = '/DocGenCommunity';
                    } else {
                        alert(event.message);
                    }
                }, {escape: true}
            );
        }

        // ─── Voting ───
        function votePost(postId) {
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.vote}', sessionToken, postId, null,
                function(result, event) { if (event.status) window.location.reload(); },
                {escape: true}
            );
        }
        function voteReply(replyId) {
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.vote}', sessionToken, null, replyId,
                function(result, event) { if (event.status) window.location.reload(); },
                {escape: true}
            );
        }

        // ─── File Upload ───
        function handleFileUpload(input, targetId) {
            var files = input.files;
            for (var i = 0; i < files.length; i++) {
                (function(file) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        var base64 = e.target.result.split(',')[1];
                        var editor = document.getElementById(targetId);
                        // Show immediate preview for images
                        var placeholderId = '';
                        if (file.type.startsWith('image/')) {
                            placeholderId = 'img-' + Date.now() + '-' + Math.random().toString(36).substr(2, 5);
                            editor.focus();
                            document.execCommand('insertHTML', false,
                                '<img id="' + placeholderId + '" src="' + e.target.result + '" alt="Uploading ' + file.name + '..." style="max-width:100%;border-radius:8px;opacity:0.6;" />');
                        }
                        Visualforce.remoting.Manager.invokeAction(
                            '{!$RemoteAction.DocGenCommunityController.uploadFile}',
                            sessionToken, file.name, base64, null,
                            function(result, event) {
                                if (event.status) {
                                    if (placeholderId) {
                                        var ph = document.getElementById(placeholderId);
                                        if (ph) { ph.src = result; ph.alt = file.name; ph.style.opacity = '1'; ph.removeAttribute('id'); }
                                    } else {
                                        editor.focus();
                                        document.execCommand('insertHTML', false, '<a href="' + result + '">' + file.name + '</a>');
                                    }
                                }
                            }, {escape: true, buffer: false}
                        );
                    };
                    reader.readAsDataURL(file);
                })(files[i]);
            }
        }

        // ─── Drag & Drop ───
        document.querySelectorAll('.upload-zone').forEach(function(zone) {
            zone.addEventListener('dragover', function(e) { e.preventDefault(); zone.classList.add('dragover'); });
            zone.addEventListener('dragleave', function() { zone.classList.remove('dragover'); });
            zone.addEventListener('drop', function(e) {
                e.preventDefault(); zone.classList.remove('dragover');
                var input = zone.querySelector('input[type="file"]');
                input.files = e.dataTransfer.files;
                input.dispatchEvent(new Event('change'));
            });
        });

        // ─── Vendor Application ───
        function doVendorApply() {
            var company = document.getElementById('vaCompany').value.trim();
            var services = document.getElementById('vaServices').value.trim();
            var website = document.getElementById('vaWebsite').value.trim();
            var certs = document.getElementById('vaCerts').value.trim();
            var message = document.getElementById('vaMessage').value.trim();
            var errEl = document.getElementById('vaError');
            errEl.textContent = '';

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.applyAsVendor}',
                sessionToken, company, services, website, certs, message,
                function(result, event) {
                    if (event.status) {
                        document.getElementById('vaBtn').style.display = 'none';
                        document.getElementById('vaSuccess').style.display = 'block';
                    } else {
                        errEl.textContent = event.message;
                    }
                }, {escape: true}
            );
        }
        // ─── Profile Edit ───
        function toggleEditProfile() {
            var form = document.getElementById('editProfileForm');
            form.style.display = form.style.display === 'none' ? 'block' : 'none';
        }
        function saveProfile() {
            var name = document.getElementById('epName').value.trim();
            var title = document.getElementById('epTitle').value.trim();
            var bio = document.getElementById('epBio').value.trim();
            var errEl = document.getElementById('epError');
            errEl.textContent = '';
            if (!name) { errEl.textContent = 'Name is required.'; return; }

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.updateProfile}', sessionToken, name, title, bio,
                function(result, event) {
                    if (event.status) {
                        window.location.reload();
                    } else {
                        errEl.textContent = event.message;
                    }
                }, {escape: true}
            );
        }

        // ─── @Mention Autocomplete ───
        var mentionState = { active: false, editorId: null, query: '', mentionedIds: [] };

        function setupMentionListener(editorId) {
            var editor = document.getElementById(editorId);
            if (!editor) return;
            editor.addEventListener('input', function(e) {
                var sel = window.getSelection();
                if (!sel.rangeCount) return;
                var range = sel.getRangeAt(0);
                var textNode = range.startContainer;
                if (textNode.nodeType !== 3) return;
                var text = textNode.textContent.substring(0, range.startOffset);
                var atIdx = text.lastIndexOf('@');
                if (atIdx >= 0 && (atIdx === 0 || text[atIdx - 1] === ' ' || text[atIdx - 1] === '\n')) {
                    var query = text.substring(atIdx + 1);
                    if (query.length >= 2 && !query.includes(' ')) {
                        mentionState.active = true;
                        mentionState.editorId = editorId;
                        mentionState.query = query;
                        searchMentions(query, editor);
                        return;
                    }
                }
                hideMentionDropdown();
            });
            editor.addEventListener('keydown', function(e) {
                if (!mentionState.active) return;
                var dd = document.getElementById('mentionDropdown');
                var items = dd.querySelectorAll('.mention-item');
                var activeIdx = -1;
                items.forEach(function(it, i) { if (it.classList.contains('active')) activeIdx = i; });
                if (e.key === 'ArrowDown') { e.preventDefault(); setMentionActive(items, Math.min(activeIdx + 1, items.length - 1)); }
                else if (e.key === 'ArrowUp') { e.preventDefault(); setMentionActive(items, Math.max(activeIdx - 1, 0)); }
                else if (e.key === 'Enter' && activeIdx >= 0) { e.preventDefault(); items[activeIdx].click(); }
                else if (e.key === 'Escape') { hideMentionDropdown(); }
            });
        }
        function setMentionActive(items, idx) {
            items.forEach(function(it) { it.classList.remove('active'); });
            if (items[idx]) items[idx].classList.add('active');
        }
        function searchMentions(query, editor) {
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.searchMembers}', query,
                function(result, event) {
                    if (!event.status || !result || !result.length) { hideMentionDropdown(); return; }
                    var dd = document.getElementById('mentionDropdown');
                    dd.innerHTML = '';
                    result.forEach(function(m) {
                        var div = document.createElement('div');
                        div.className = 'mention-item';
                        div.innerHTML = m.name + (m.company ? ' <span class="company">' + m.company + '</span>' : '');
                        div.onclick = function() { insertMention(m.id, m.name); };
                        dd.appendChild(div);
                    });
                    // Position near cursor
                    var rect = editor.getBoundingClientRect();
                    dd.style.left = (rect.left + 20) + 'px';
                    dd.style.top = (rect.bottom - 10) + 'px';
                    dd.style.display = 'block';
                    if (dd.querySelector('.mention-item')) dd.querySelector('.mention-item').classList.add('active');
                }, {escape: false}
            );
        }
        function insertMention(contactId, name) {
            hideMentionDropdown();
            var editor = document.getElementById(mentionState.editorId);
            if (!editor) return;
            // Remove the @query text and insert the mention link
            var sel = window.getSelection();
            var range = sel.getRangeAt(0);
            var textNode = range.startContainer;
            var text = textNode.textContent;
            var offset = range.startOffset;
            var atIdx = text.lastIndexOf('@', offset - 1);
            if (atIdx >= 0) {
                textNode.textContent = text.substring(0, atIdx) + text.substring(offset);
                range.setStart(textNode, atIdx);
                range.collapse(true);
                sel.removeAllRanges();
                sel.addRange(range);
                document.execCommand('insertHTML', false,
                    '<a href="/DocGenCommunity?view=profile&amp;mid=' + contactId + '" class="mention-tag" data-mention-id="' + contactId + '">@' + name + '</a>&nbsp;');
            }
            mentionState.mentionedIds.push(contactId);
            mentionState.active = false;
        }
        function hideMentionDropdown() {
            document.getElementById('mentionDropdown').style.display = 'none';
            mentionState.active = false;
        }
        // Initialize mention listeners on all editors
        document.addEventListener('DOMContentLoaded', function() {
            ['npBody', 'replyBody', 'editBody'].forEach(function(id) { setupMentionListener(id); });
            document.addEventListener('click', function(e) {
                if (!e.target.closest('.mention-dropdown') && !e.target.closest('.rte-editor')) {
                    hideMentionDropdown();
                }
            });
        });

        // ─── Account & Org Management ───
        function loadMyOrgs() {
            var container = document.getElementById('orgList');
            if (!container) return;
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.getMyOrgs}', sessionToken,
                function(result, event) {
                    if (!event.status) { container.innerHTML = '<p style="color: #f87171; font-size: 0.85rem;">' + event.message + '</p>'; return; }
                    if (!result || result.length === 0) {
                        container.innerHTML = '<p style="color: #475569; font-size: 0.85rem;">No orgs linked yet. Add your Org ID below to connect your Salesforce org.</p>';
                        return;
                    }
                    var html = '';
                    result.forEach(function(org) {
                        var statusClass = org.status === 'Installed' ? 'status-installed' : 'status-other';
                        html += '<div class="org-item">'
                            + '<div class="org-info">'
                            + '<div class="org-name">' + (org.name || org.orgId) + '</div>'
                            + '<div class="org-meta">' + (org.orgId || '') + (org.version ? ' &bull; ' + org.version : '') + (org.orgType ? ' &bull; ' + org.orgType : '') + '</div>'
                            + '</div>'
                            + '<span class="org-status ' + statusClass + '">' + (org.status || 'Unknown') + '</span>'
                            + ' <button type="button" class="btn-remove" onclick="removeOrg(\'' + org.id + '\')">Remove</button>'
                            + '</div>';
                    });
                    container.innerHTML = html;
                }, {escape: false}
            );
        }
        function addOrg() {
            var orgId = document.getElementById('newOrgId').value.trim();
            var errEl = document.getElementById('addOrgError');
            errEl.textContent = '';
            if (!orgId || orgId.length < 15) { errEl.textContent = 'Enter a valid 15 or 18 character Org ID.'; return; }

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.addOrg}', sessionToken, orgId,
                function(result, event) {
                    if (event.status) {
                        document.getElementById('newOrgId').value = '';
                        if (result === 'already_linked') { errEl.textContent = 'This org is already linked to your account.'; errEl.style.color = '#fbbf24'; }
                        else { loadMyOrgs(); }
                    } else {
                        errEl.textContent = event.message;
                    }
                }, {escape: true}
            );
        }
        function removeOrg(subOrgId) {
            if (!confirm('Remove this org from your account?')) return;
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.removeOrg}', sessionToken, subOrgId,
                function(result, event) {
                    if (event.status) { loadMyOrgs(); }
                    else { alert(event.message); }
                }, {escape: true}
            );
        }
        function updateCompany() {
            var name = document.getElementById('companyName').value.trim();
            var errEl = document.getElementById('companyError');
            errEl.textContent = '';
            if (!name) { errEl.textContent = 'Company name is required.'; return; }

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.DocGenCommunityController.updateCompany}', sessionToken, name,
                function(result, event) {
                    if (event.status) { window.location.reload(); }
                    else { errEl.textContent = event.message; }
                }, {escape: true}
            );
        }
        // Load orgs when profile page renders
        document.addEventListener('DOMContentLoaded', function() {
            if (document.getElementById('orgList')) { loadMyOrgs(); }
        });

        // Pre-select category and topics from URL params
        (function() {
            var params = new URLSearchParams(window.location.search);
            var precat = params.get('precat');
            var pretopic = params.get('pretopic');
            var sel = document.getElementById('npCategory');
            var topicInput = document.getElementById('npTopics');
            if (precat && sel) { sel.value = precat; }
            if (pretopic && topicInput) { topicInput.value = pretopic; }
        })();
    </script>

</body>
</html>
</apex:page>
