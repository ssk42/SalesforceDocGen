<apex:page controller="DocGenLandingController" showHeader="false" standardStylesheets="false" sidebar="false" applyHtmlTag="true" applyBodyTag="false" docType="html-5.0" cache="true">
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Community — Portwood DocGen</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #e2e8f0; background: #0f172a; line-height: 1.6; }
        a { color: #60a5fa; text-decoration: none; } a:hover { text-decoration: underline; }

        /* Header */
        .header { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border-bottom: 1px solid rgba(255,255,255,0.06); padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; }
        .logo { font-size: 1.25rem; font-weight: 700; letter-spacing: -0.5px; color: #fff; text-decoration: none; } .logo span { color: #60a5fa; }
        .header-links a { color: #94a3b8; margin-left: 1.5rem; font-size: 0.9rem; font-weight: 500; text-decoration: none; } .header-links a:hover { color: #fff; }

        /* Hero */
        .hero { background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%); text-align: center; padding: 5rem 2rem 4rem; }
        .hero h1 { font-size: 2.75rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 1rem; line-height: 1.1; color: #fff; }
        .hero h1 em { font-style: normal; color: #60a5fa; }
        .hero p { font-size: 1.15rem; color: #94a3b8; max-width: 680px; margin: 0 auto 2.5rem; }
        .btn { display: inline-block; padding: 16px 40px; border-radius: 50px; font-size: 1.1rem; font-weight: 700; text-decoration: none; cursor: pointer; border: none; transition: transform 0.2s, box-shadow 0.2s; }
        .btn:hover { transform: translateY(-2px); text-decoration: none; }
        .btn-slack { background: #4A154B; color: #fff; box-shadow: 0 4px 14px rgba(74,21,75,0.4); font-size: 1.1rem; }
        .btn-slack:hover { box-shadow: 0 6px 20px rgba(74,21,75,0.5); }
        .btn-secondary { background: rgba(255,255,255,0.08); color: #fff; border: 2px solid rgba(255,255,255,0.15); margin-left: 1rem; font-size: 1rem; padding: 14px 32px; }
        .btn-secondary:hover { background: rgba(255,255,255,0.12); }
        .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
        .slack-logo { display: inline-block; vertical-align: middle; margin-right: 0.5rem; width: 22px; height: 22px; }

        /* Section */
        .section { max-width: 960px; margin: 0 auto; padding: 4rem 2rem; }
        .section h2 { font-size: 2rem; font-weight: 800; text-align: center; margin-bottom: 0.5rem; color: #fff; }
        .section .subtitle { text-align: center; color: #64748b; margin-bottom: 3rem; font-size: 1.05rem; }

        /* Channel cards */
        .channel-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
        .channel-card { background: #1e293b; border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 1.5rem; transition: border-color 0.2s; }
        .channel-card:hover { border-color: rgba(255,255,255,0.12); }
        .channel-name { font-size: 1.05rem; font-weight: 700; color: #fff; margin-bottom: 0.35rem; }
        .channel-name span { color: #94a3b8; font-weight: 400; }
        .channel-card p { color: #94a3b8; font-size: 0.88rem; }
        .cc-features { border-left: 3px solid #a855f7; }
        .cc-qa { border-left: 3px solid #fbbf24; }
        .cc-bugs { border-left: 3px solid #f87171; }
        .cc-show { border-left: 3px solid #4ade80; }
        .cc-templates { border-left: 3px solid #06b6d4; }
        .cc-general { border-left: 3px solid #60a5fa; }
        .cc-announce { border-left: 3px solid #f97316; }

        /* Why Slack */
        .why-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-top: 2rem; }
        .why-card { background: #1e293b; border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 1.25rem; text-align: center; }
        .why-card h4 { font-size: 0.95rem; font-weight: 700; color: #fff; margin-bottom: 0.25rem; }
        .why-card p { color: #64748b; font-size: 0.8rem; }
        .why-icon { font-size: 1.5rem; margin-bottom: 0.5rem; display: block; }

        /* Client channels callout */
        .client-callout { background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); border: 2px solid rgba(96,165,250,0.2); border-radius: 16px; padding: 2rem; text-align: center; margin-top: 3rem; }
        .client-callout h3 { font-size: 1.25rem; font-weight: 800; color: #fff; margin-bottom: 0.5rem; }
        .client-callout p { color: #94a3b8; font-size: 0.95rem; max-width: 600px; margin: 0 auto; }

        /* CTA */
        .cta-section { background: linear-gradient(135deg, #4A154B 0%, #2c0a2d 100%); text-align: center; padding: 4rem 2rem; }
        .cta-section h2 { font-size: 2rem; font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
        .cta-section p { color: rgba(255,255,255,0.6); max-width: 600px; margin: 0 auto 2rem; font-size: 1.05rem; }

        /* Footer */
        .footer { border-top: 1px solid rgba(255,255,255,0.06); padding: 2rem; text-align: center; color: #475569; font-size: 0.8rem; }
        .footer a { color: #60a5fa; }
        .footer-links { margin-bottom: 0.75rem; }
        .footer-links a { margin: 0 0.75rem; }

        @media (max-width: 700px) {
            .hero h1 { font-size: 2rem; }
            .hero-actions { flex-direction: column; align-items: center; }
            .btn-secondary { margin-left: 0; }
            .header { flex-direction: column; gap: 0.5rem; }
            .header-links a { margin-left: 0.75rem; }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header class="header">
        <a href="/DocGenLanding" class="logo">Portwood <span>DocGen</span></a>
        <nav class="header-links">
            <a href="/DocGenLanding">Home</a>
            <a href="/DocGenRoadmap">Roadmap</a>
            <a href="https://github.com/Portwood-Global-Solutions/Portwood-DocGen">GitHub</a>
        </nav>
    </header>

    <!-- Hero -->
    <section class="hero">
        <h1>Join the DocGen <em>Community</em></h1>
        <p>Connect with Salesforce admins and developers building documents with DocGen. Get help, request features, share templates, and shape the roadmap — all on Slack.</p>
        <div class="hero-actions">
            <a href="{!slackInviteUrl}" class="btn btn-slack" target="_blank">
                <svg class="slack-logo" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z" fill="#fff"/></svg>
                Join on Slack
            </a>
            <a href="https://github.com/Portwood-Global-Solutions/Portwood-DocGen" class="btn btn-secondary" target="_blank">Star on GitHub</a>
        </div>
    </section>

    <!-- Channels -->
    <section class="section">
        <h2>Channels</h2>
        <p class="subtitle">Jump into the conversation that matters to you</p>
        <div class="channel-grid">
            <div class="channel-card cc-announce">
                <div class="channel-name"><span>#</span> announcements</div>
                <p>Release notes, new features, and important updates from the DocGen team.</p>
            </div>
            <div class="channel-card cc-features">
                <div class="channel-name"><span>#</span> feature-requests</div>
                <p>Suggest new features and vote on what gets built next. The community drives the roadmap.</p>
            </div>
            <div class="channel-card cc-qa">
                <div class="channel-name"><span>#</span> help</div>
                <p>Get help with templates, merge tags, query configs, Flows, and anything else DocGen-related.</p>
            </div>
            <div class="channel-card cc-bugs">
                <div class="channel-name"><span>#</span> bug-reports</div>
                <p>Found something broken? Report it here. We triage and fix bugs fast.</p>
            </div>
            <div class="channel-card cc-templates">
                <div class="channel-name"><span>#</span> template-sharing</div>
                <p>Share and discover ready-to-use Word templates. Help others get started faster.</p>
            </div>
            <div class="channel-card cc-show">
                <div class="channel-name"><span>#</span> show-and-tell</div>
                <p>Share what you've built with DocGen — invoices, contracts, reports, creative use cases.</p>
            </div>
            <div class="channel-card cc-general">
                <div class="channel-name"><span>#</span> general</div>
                <p>Everything else — tips and tricks, Salesforce news, off-topic chat.</p>
            </div>
        </div>

        <!-- Client channels callout -->
        <div class="client-callout">
            <h3>Need dedicated support?</h3>
            <p>We create private client channels for orgs that need hands-on help with implementation, custom templates, or complex setups. Join Slack and let us know — we'll spin one up for you.</p>
        </div>
    </section>

    <!-- Why Slack -->
    <section class="section" style="padding-top: 0;">
        <h2>Why Slack?</h2>
        <p class="subtitle">Modern community for modern admins</p>
        <div class="why-grid">
            <div class="why-card">
                <span class="why-icon">&#x26A1;</span>
                <h4>Real-Time</h4>
                <p>Get answers in minutes, not days. Live chat with the team and community.</p>
            </div>
            <div class="why-card">
                <span class="why-icon">&#x1F514;</span>
                <h4>Notifications</h4>
                <p>Desktop, mobile, and email notifications. Never miss a reply or @mention.</p>
            </div>
            <div class="why-card">
                <span class="why-icon">&#x1F4CE;</span>
                <h4>Rich Media</h4>
                <p>Drag and drop screenshots, paste images, share templates and files inline.</p>
            </div>
            <div class="why-card">
                <span class="why-icon">&#x1F50D;</span>
                <h4>Searchable</h4>
                <p>Every conversation is searchable. Find answers to questions already asked.</p>
            </div>
            <div class="why-card">
                <span class="why-icon">&#x1F4F1;</span>
                <h4>Mobile App</h4>
                <p>Stay connected on the go with Slack's iOS and Android apps.</p>
            </div>
            <div class="why-card">
                <span class="why-icon">&#x1F6E1;</span>
                <h4>Private Channels</h4>
                <p>Dedicated client channels for orgs that need direct support.</p>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
        <h2>Ready to join?</h2>
        <p>It takes 10 seconds. Free forever. No email required — just click and you're in.</p>
        <a href="{!slackInviteUrl}" class="btn btn-slack" target="_blank" style="background: #fff; color: #4A154B;">
            <svg style="width: 22px; height: 22px; vertical-align: middle; margin-right: 0.5rem;" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z" fill="#4A154B"/></svg>
            Join the DocGen Slack
        </a>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-links">
            <a href="/DocGenLanding">Home</a>
            <a href="/DocGenCommunity">Community</a>
            <a href="/DocGenRoadmap">Roadmap</a>
            <a href="https://github.com/Portwood-Global-Solutions/Portwood-DocGen">GitHub</a>
            <a href="/DocGenTerms">Terms</a>
            <a href="/DocGenPrivacy">Privacy</a>
        </div>
        <p>Built by <a href="https://portwoodglobalsolutions.com">Portwood Global Solutions</a></p>
    </footer>

</body>
</html>
</apex:page>
