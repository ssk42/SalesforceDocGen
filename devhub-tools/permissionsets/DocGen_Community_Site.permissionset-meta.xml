    <!-- Apex class access — this is what authorizes the controller to run DML in system context -->
    <classAccesses>
        <apexClass>DocGenCommunityController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DocGenLandingController</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- VF page access — allows the site to serve these pages -->
    <pageAccesses>
        <apexPage>DocGenCommunity</apexPage>
        <enabled>true</enabled>
    </pageAccesses>
    <pageAccesses>
        <apexPage>DocGenLanding</apexPage>
        <enabled>true</enabled>
    </pageAccesses>
    <pageAccesses>
        <apexPage>DocGenTerms</apexPage>
        <enabled>true</enabled>
    </pageAccesses>
    <pageAccesses>
        <apexPage>DocGenPrivacy</apexPage>
        <enabled>true</enabled>
    </pageAccesses>
</PermissionSet>
