<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Guest user permissions for DocGen Community VF Site. Grants Apex class + VF page access only. All DML runs in system context via without sharing + SYSTEM_MODE in the controller.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>DocGen Community Site</label>

    <!-- Read-only object access for VF page field rendering -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>DocGen_Community_Post__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>DocGen_Community_Reply__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Read-only field access for VF page rendering -->
    <fieldPermissions>
        <editable>false</editable>
        <field>DocGen_Community_Post__c.Body__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>DocGen_Community_Post__c.Topics__c</field>
        <readable>true</readable>
    </fieldPermissions>
